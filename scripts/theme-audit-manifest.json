        { "selector": ".dtg-block, .dtg-block-title", "reason": "Geometry-bound labels in fixed-duration blocks; title, time and location remain available through an accessible name and detail dialog.", "stableSurface": "opaque --card-bg bounded block", "zoomEvidence": "journey session-modal at 200%" },
        { "selector": ".dtg-block-time, .dtg-block-loc", "reason": "Secondary metadata in the same bounded block; not an instruction, control, error or sole state cue.", "stableSurface": "opaque --card-bg bounded block", "zoomEvidence": "journey session-modal at 200%" }
