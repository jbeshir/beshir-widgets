{
  // Cloudflare Worker serving the Pennsic Planner static bundle.
  "name": "widget-pennsic-planner",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./dist/",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "pennsic-planner.widgets.beshir.org",
      "custom_domain": true
    }
  ]
}
