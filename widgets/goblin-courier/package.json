{
  "name": "widget-goblin-courier",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "assets": "node scripts/extract-assets.cjs",
    "build:test": "npm run typecheck && cross-env GAME_TEST_BUILD=1 vite build --outDir dist-test",
    "build": "npm run typecheck && cross-env GAME_TEST_BUILD=0 vite build --outDir dist",
    "typecheck": "tsc --noEmit",
    "playtest": "node test/playtest.cjs",
    "validate:production": "node test/validate-production.cjs dist/index.html"
  },
  "dependencies": { "@fontsource/schibsted-grotesk": "5.2.8", "preact": "10.27.2" },
  "devDependencies": {
    "@preact/preset-vite": "2.10.2",
    "adm-zip": "0.5.16",
    "cross-env": "7.0.3",
    "playwright": "1.61.1",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  }
}
